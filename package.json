{
  "name": "aidekin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "Sait Furkan Teke",
  "description": "aidekin: a 100% client-side, embeddable voice and text AI widget that runs entirely in the browser (WebGPU). No backend, no API keys, no per-message cost.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --config vite.loader.config.ts",
    "build:app": "vite build",
    "build:loader": "vite build --config vite.loader.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fetch-models": "node scripts/fetch-models.mjs",
    "build-knowledge": "tsx scripts/build-knowledge.ts",
    "verify-knowledge": "tsx scripts/verify-knowledge.ts",
    "verify-tokenizer": "tsx scripts/verify-tokenizer.ts",
    "verify-embedder": "tsx scripts/verify-embedder.ts",
    "verify-turn": "tsx scripts/verify-turn.ts",
    "eval:chat": "node scripts/eval-chat.mjs",
    "eval:session": "node scripts/eval-session.mjs",
    "lint": "eslint .",
    "verify-lint": "tsx scripts/verify-lint.ts"
  },
  "dependencies": {
    "@huggingface/tokenizers": "0.1.3",
    "@ricky0123/vad-web": "0.0.30",
    "bitgpu": "0.13.0",
    "clsx": "2.1.1",
    "fft.js": "4.0.4",
    "lucide-react": "1.23.0",
    "mammoth": "1.12.0",
    "onnxruntime-web": "1.27.0",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@huggingface/transformers": "4.2.0",
    "@radix-ui/colors": "3.0.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@webgpu/types": "0.1.71",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "onnxruntime-node": "1.24.3",
    "playwright-core": "1.61.1",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3"
  }
}
