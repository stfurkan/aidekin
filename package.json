{
  "name": "aidekin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "Sait Furkan Teke",
  "description": "aidekin: a 100% client-side, embeddable voice and text AI widget that runs entirely in the browser (WebGPU). No backend, no API keys, no per-message cost.",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build:engine": "npm run build -w @aidekin/webgpu-llm",
    "build": "npm run build:engine && tsc --noEmit && vite build && vite build --config vite.loader.config.ts",
    "build:app": "vite build",
    "build:loader": "vite build --config vite.loader.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fetch-models": "node scripts/fetch-models.mjs",
    "build-knowledge": "tsx scripts/build-knowledge.ts",
    "verify-knowledge": "tsx scripts/verify-knowledge.ts",
    "verify-tokenizer": "tsx scripts/verify-tokenizer.ts"
  },
  "dependencies": {
    "@aidekin/webgpu-llm": "*",
    "@huggingface/jinja": "0.5.9",
    "@huggingface/tokenizers": "0.1.3",
    "@huggingface/transformers": "4.2.0",
    "@ricky0123/vad-web": "0.0.30",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fft.js": "4.0.4",
    "lucide-react": "1.21.0",
    "mammoth": "1.12.0",
    "onnxruntime-web": "1.27.0",
    "pdfjs-dist": "6.0.227",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@radix-ui/colors": "3.0.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@webgpu/types": "0.1.70",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
